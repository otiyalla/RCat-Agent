# ─────────────────────────────────────────────────────────────
# RevenueCat Developer Advocate Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Human operator identity
OPERATOR_NAME=Your Name
OPERATOR_EMAIL=you@example.com

# RevenueCat (get from dashboard → API Keys)
REVENUECAT_API_KEY=appl_...
REVENUECAT_PROJECT_ID=proj_...

# Optional: publishing integrations
GITHUB_TOKEN=ghp_...            # for GitHub Gist auto-publishing
TWITTER_BEARER_TOKEN=...        # for Twitter/X posting

# Optional: web search (Tavily)
TAVILY_API_KEY=tvly-...

# Behaviour
DRY_RUN=true                    # Set to 'false' to enable real API calls
AGENT_DATA_DIR=./data           # Where logs and JSON records are stored
